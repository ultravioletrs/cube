# Probot UI environment variables
# Copy to .env.local (git-ignored) and adjust for your setup.
# All VITE_* variables are inlined at build time and visible in the browser.
# Never put secrets here.

# Base URL of the Magistrala Users service reachable from the browser.
# For local dev: leave unset — the dev server proxy rewrites /users/* → http://localhost:9002
VITE_MAGISTRALA_USERS_URL=http://localhost:9002

# Google OAuth Client ID for "Sign in with Google" login.
# Create at: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Type: Web application. Add http://localhost:5173 as an Authorized JavaScript origin.
VITE_OAUTH_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
