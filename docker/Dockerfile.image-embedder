FROM python:3.12-slim

WORKDIR /app

COPY image-embedder/requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

COPY image-embedder/main.py /app/main.py

EXPOSE 8090

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8090"]
