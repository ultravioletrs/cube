# Production environment for Cube. Override every secret before deploying.

# Public domain served by Traefik (Let's Encrypt issues TLS for it).
CUBE_DOMAIN=cube.example.com

# Image tag for cube-built images. Matches `make docker VERSION=...`.
CUBE_TAG=latest

# Traefik host ports
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TRAEFIK_DASHBOARD_PORT=8090

# Optional Cloudflare tunnel (enable with: --profile tunnel)
TUNNEL_TOKEN=

# Ollama models
LLM_MODEL=llama3.2:3b
EMBEDDING_MODEL=nomic-embed-text:v1.5

# Attestation / aTLS (TEE only). Keep false on non-TEE hosts.
ATTESTED_TLS=false
ATOM_CERTS_ENABLED=true
ATOM_CERTS_TOKEN=
ATOM_ENTITY_ID=

# ATOM identity
ATOM_DB_USER=atom
ATOM_DB_PASS=change-me-atom
ATOM_DB_NAME=atom
ATOM_ADMIN_SECRET=change-me-admin

# Cube proxy database
PROXY_DB_USER=cube
PROXY_DB_PASS=change-me-proxy
PROXY_DB_NAME=cube-proxy

# Cube embedder database
EMBEDDER_DB_USER=veda
EMBEDDER_DB_PASS=change-me-embedder
EMBEDDER_DB_NAME=veda

# Guardrails database
GUARDRAILS_DB_USER=guardrails
GUARDRAILS_DB_PASS=change-me-guardrails
GUARDRAILS_DB_NAME=guardrails
