# Local development environment for Cube. Safe defaults, not for production.

# Image tag for cube-built images (proxy/agent/embedder). Matches `make docker`.
CUBE_TAG=latest

# Host ports
UI_PORT=5173
PROXY_PORT=8900
EMBEDDER_PORT=8082
ATOM_HTTP_PORT=8080
ATOM_GRPC_PORT=8081
ATOM_UI_PORT=3005

# Ollama models
LLM_MODEL=llama3.2:3b
EMBEDDING_MODEL=nomic-embed-text:v1.5

# ATOM identity
ATOM_DB_USER=atom
ATOM_DB_PASS=atom
ATOM_DB_NAME=atom
ATOM_ADMIN_SECRET=12345678

# Cube proxy database
PROXY_DB_USER=cube
PROXY_DB_PASS=cube
PROXY_DB_NAME=cube-proxy

# Cube embedder database
EMBEDDER_DB_USER=veda
EMBEDDER_DB_PASS=veda
EMBEDDER_DB_NAME=veda
