# Docker: Environment variables in Compose

# ATOM database and runtime.
ATOM_POSTGRES_USER=atom
ATOM_POSTGRES_PASSWORD=atom-dev-only
ATOM_POSTGRES_DB=atom
ATOM_ADMIN_SECRET=12345678
ATOM_MIN_PASSWORD_CHARS=8
ATOM_HTTP_PORT=8080
ATOM_GRPC_PORT=8081
ATOM_GRPC_URL=atom:8081
ATOM_GRAPHQL_URL=http://atom:8080/graphql
ATOM_TIMEOUT=15s
ATOM_UI_HTTP_PORT=3005
ATOM_CORS_ALLOWED_ORIGINS=http://localhost:6193,http://localhost:5173,http://localhost:3005
ATOM_AUTH_COOKIE_SECURE=false
ATOM_AUTH_COOKIE_DOMAIN=

# ATOM certificate authority files. The smoke target creates local dev files in
# docker/certs if these paths do not exist.
ATOM_CERTS_ENABLED=true
ATOM_CERTS_CA_MODE=file_intermediate_issuer
ATOM_CERTS_CA_DIR=./certs
ATOM_CERTS_ROOT_CA_CERT_PATH=/certs/root-ca.crt
ATOM_CERTS_INTERMEDIATE_CA_CERT_PATH=/certs/intermediate-ca.crt
ATOM_CERTS_INTERMEDIATE_CA_KEY_PATH=/certs/intermediate-ca.key

# Cube proxy.
UV_CUBE_PROXY_LOG_LEVEL=debug
UV_CUBE_PROXY_HOST=0.0.0.0
UV_CUBE_PROXY_PORT=8900
UV_CUBE_PROXY_SERVER_CERT=
UV_CUBE_PROXY_SERVER_KEY=
UV_CUBE_PROXY_INSTANCE_ID=
UV_CUBE_PROXY_ROUTER_CONFIG=/etc/cube/proxy/config.json
UV_CUBE_PROXY_SERVER_WRITE_TIMEOUT=120s
UV_CUBE_PROXY_SERVER_READ_TIMEOUT=120s
UV_CUBE_AGENT_URL=http://cube-agent:8901

# Cube proxy database.
UV_CUBE_PROXY_DB_HOST=cube-proxy-db
UV_CUBE_PROXY_DB_PORT=5432
UV_CUBE_PROXY_DB_USER=cube
UV_CUBE_PROXY_DB_PASS=cube
UV_CUBE_PROXY_DB_NAME=cube-proxy
UV_CUBE_PROXY_DB_SSL_MODE=disable
UV_CUBE_PROXY_DB_SSL_CERT=
UV_CUBE_PROXY_DB_SSL_KEY=
UV_CUBE_PROXY_DB_SSL_ROOT_CERT=

# Cube agent.
UV_CUBE_AGENT_TARGET_URL=http://ollama:11434
UV_CUBE_AGENT_LOG_LEVEL=debug
UV_CUBE_AGENT_HOST=0.0.0.0
UV_CUBE_AGENT_PORT=8901
UV_CUBE_AGENT_SERVER_CERT=
UV_CUBE_AGENT_SERVER_KEY=
UV_CUBE_AGENT_INSTANCE_ID=
UV_CUBE_AGENT_CERTS_TOKEN=
UV_CUBE_AGENT_ENTITY_ID=
UV_CUBE_AGENT_CLIENT_CERT=
UV_CUBE_AGENT_CLIENT_KEY=
UV_CUBE_AGENT_SERVER_CA_CERTS=/etc/cube/atom-certs/root-ca.crt
UV_CUBE_AGENT_ATTESTED_TLS=false
UV_CUBE_AGENT_ATTESTATION_POLICY=
UV_CUBE_AGENT_PRODUCT_NAME=Milan

# Embedder.
EMBEDDER_PORT=8082
EMBEDDER_HTTP_ADDR=:8082
EMBEDDER_DB_USER=veda
EMBEDDER_DB_PASS=veda
EMBEDDER_DB_NAME=veda
EMBEDDER_AUTH_GRPC_URL=atom:8081
EMBEDDER_GOOGLE_OAUTH_CLIENT_ID=
EMBEDDER_GOOGLE_OAUTH_CLIENT_SECRET=
EMBEDDER_EMBEDDING_DEFAULT_PROFILE=text
EMBEDDER_EMBEDDING_PROFILE_BY_SOURCE_TYPE={}
EMBEDDER_EMBEDDING_PROFILE_BY_RECORD_FORMAT={"text":"text","md":"text","pdf":"text","docx":"text","link":"text","code":"code","image":"image"}
EMBEDDER_EMBEDDING_TEXT_PROVIDER=ollama
EMBEDDER_EMBEDDING_TEXT_BASE_URL=http://ollama:11434
EMBEDDER_EMBEDDING_TEXT_MODEL=nomic-embed-text:v1.5
EMBEDDER_EMBEDDING_TEXT_DIMENSIONS=768
EMBEDDER_EMBEDDING_TEXT_API_KEY=
EMBEDDER_EMBEDDING_CODE_PROVIDER=ollama
EMBEDDER_EMBEDDING_CODE_BASE_URL=http://ollama:11434
EMBEDDER_EMBEDDING_CODE_MODEL=nomic-embed-text:v1.5
EMBEDDER_EMBEDDING_CODE_DIMENSIONS=768
EMBEDDER_EMBEDDING_CODE_API_KEY=
EMBEDDER_EMBEDDING_IMAGE_PROVIDER=ollama
EMBEDDER_EMBEDDING_IMAGE_BASE_URL=http://ollama:11434
EMBEDDER_EMBEDDING_IMAGE_MODEL=nomic-embed-text:v1.5
EMBEDDER_EMBEDDING_IMAGE_DIMENSIONS=768
EMBEDDER_EMBEDDING_IMAGE_API_KEY=
EMBEDDER_EMBEDDING_PROFILES=
EMBEDDER_EMBEDDING_SELECTION=
EMBEDDER_CHUNK_SIZE=512
EMBEDDER_CHUNK_OVERLAP=64
EMBEDDER_INGEST_BATCH_SIZE=20
EMBEDDER_INGEST_MAX_CONCURRENCY=4
EMBEDDER_INGEST_POLL_INTERVAL=3s
EMBEDDER_INGEST_EMBED_BATCH_SIZE=16
EMBEDDER_OBJECT_STORAGE_PROVIDER=local
EMBEDDER_OBJECT_STORAGE_PREFIX=uploads
EMBEDDER_UPLOAD_DIR=/tmp/embedder/uploads
EMBEDDER_OCR_ENABLED=false
EMBEDDER_OCR_IMAGE_ENABLED=true
EMBEDDER_OCR_PDF_FALLBACK_ENABLED=true
EMBEDDER_OCR_LANG=eng
EMBEDDER_OCR_BINARY=tesseract
EMBEDDER_OCR_PDF_RENDER_BINARY=pdftoppm
EMBEDDER_OCR_TIMEOUT=2m
EMBEDDER_OCR_MIN_TEXT_CHARS=40
EMBEDDER_OCR_MAX_PDF_PAGES=20
EMBEDDER_LOG_LEVEL=info
EMBEDDER_OLLAMA_BASE_URL=http://ollama:11434
EMBEDDER_LLM_PROVIDER=ollama
EMBEDDER_LLM_BASE_URL=http://ollama:11434

# ==============================================================================
# LLM CONFIGURATION & HARDWARE BASELINES
# Source: Ollama / Qwen
# ==============================================================================

# 🛑 BASELINE 1: CPU Only / Weak Machines (~2GB VRAM/RAM required)
# Characteristics: Fastest usable baseline, low resource footprint
# EMBEDDER_LLM_MODEL=llama3.2:3b

# ⚖️ BASELINE 2: 8GB RAM / Small GPU (Recommended Default)
# Characteristics: Best speed-to-quality balance
EMBEDDER_LLM_MODEL=llama3.2:3b

# 🔥 BASELINE 3: 8-12GB VRAM / Dedicated GPU
# Characteristics: Higher quality answers, requires more resource management
# EMBEDDER_LLM_MODEL=qwen3:8b

EMBEDDER_LLM_API_KEY=
EMBEDDER_CHAT_TOP_K=8
EMBEDDER_RERANKER_MODEL=
EMBEDDER_RERANKER_BASE_URL=

# Guardrails.
UV_GUARDRAILS_DB_HOST=cube-guardrails-db
UV_GUARDRAILS_DB_PORT=5432
UV_GUARDRAILS_DB_USER=guardrails
UV_GUARDRAILS_DB_PASS=guardrails
UV_GUARDRAILS_DB_NAME=guardrails
GUARDRAILS_BASE_URL=http://guardrails:8001

# UI.
UI_PORT=6193
CUBE_PROXY_TARGET=http://cube-proxy:${UV_CUBE_PROXY_PORT}
VITE_CUBE_PROXY_URL=http://localhost:${UI_PORT}
VITE_ATOM_API_URL=http://localhost:${ATOM_HTTP_PORT}
VITE_ATOM_GRAPHQL_URL=http://localhost:${ATOM_HTTP_PORT}/graphql
VITE_ATOM_UI_URL=http://localhost:${ATOM_UI_HTTP_PORT}

# Local model runtimes.
AI_BACKEND=ollama
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
VLLM_LOGGING_LEVEL=INFO

# Edge routing.
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TRAEFIK_DASHBOARD_PORT=8090
TUNNEL_TOKEN=
