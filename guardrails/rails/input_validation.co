flow user ask unethical_request
  user said "help me cheat"
    or user said "how to manipulate people"
    or user said "help me lie"
    or user said "how to scam"
    or user said "help me plagiarize"
    or user said "how to deceive someone"
    or user said "help me break rules"
    or user said "how to exploit others"

# ---------------------------------------------------------------------------
# Main input guard – runs with high priority so it fires BEFORE llm
# continuation picks up the user utterance.
# The @loop decorator lets it re-arm after each match.
# ---------------------------------------------------------------------------

@loop("input_guard")
flow input guard
  priority 0.9
  when user ask jailbreak
    bot refuse jailbreak_attempt
  or when user ask prompt_injection
    bot refuse prompt_injection
  or when user ask toxicity
    bot refuse toxic_content
  or when user ask restricted_topics
    bot refuse restricted_topic
  or when user request illegal_activity
    bot decline illegal_activity
  or when user use hate_speech
    bot decline hate_speech
  or when user ask gender_bias
    bot refuse inappropriate_request
  or when user ask racial_bias
    bot refuse inappropriate_request
  or when user ask religious_bias
    bot refuse inappropriate_request
  or when user ask age_bias
    bot refuse inappropriate_request
  or when user ask politics
    bot decline politics
  or when user ask personal_beliefs
    bot decline personal_beliefs
  or when user ask unethical_request
    bot decline unethical_request
