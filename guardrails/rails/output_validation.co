import core

flow bot inform output_unsafe
  bot say "I need to revise my response to ensure it meets safety guidelines."

flow bot inform potential_hallucination
  bot say "Let me provide a more careful and accurate response."

flow match_bot_show_hallucination
  bot said "definitely will happen in 2025" or bot said "certainly will happen in 2024" or bot said "absolutely will occur next year" or bot said "everyone agrees that" or bot said "no one believes that" or bot said "all experts say" or bot said "never happens" or bot said "always results in" or bot said "100% certain" or bot said "guaranteed to happen" or bot said "without a doubt will" or bot said "definitely going to" or bot said "certainly going to" or bot said "absolutely going to" or bot said "everyone knows" or bot said "nobody thinks" or bot said "all people believe" or bot said "never works" or bot said "always fails"

flow match_bot_show_unsafe_content
  bot said "violence against" or bot said "how to harm" or bot said "ways to hurt" or bot said "methods to damage" or bot said "techniques for violence" or bot said "explicit sexual content" or bot said "inappropriate material" or bot said "offensive language" or bot said "personal information of" or bot said "private data about" or bot said "sensitive details regarding" or bot said "confidential information" or bot said "classified data" or bot said "social security number" or bot said "credit card information" or bot said "password for" or bot said "login credentials"

flow match_bot_show_gender_bias
  bot said "women are naturally bad at" or bot said "men are naturally good at" or bot said "girls should focus on" or bot said "boys should focus on" or bot said "women belong in" or bot said "men belong in" or bot said "typical female behavior" or bot said "typical male behavior" or bot said "women can't handle" or bot said "men don't understand"

flow match_bot_show_racial_bias
  bot said "people of [race] are naturally" or bot said "[race] people typically" or bot said "[race] culture is inferior" or bot said "[race] people can't" or bot said "typical [race] behavior"

flow match_bot_show_religious_bias
  bot said "[religion] people are extremists" or bot said "[religion] is a dangerous cult" or bot said "[religion] promotes violence" or bot said "[religion] believers are"

flow match_bot_show_restricted_topics
  bot said "how to make explosives" or bot said "bomb making instructions" or bot said "weapon manufacturing" or bot said "illegal drug synthesis" or bot said "hacking techniques" or bot said "suicide methods" or bot said "violence against children" or bot said "identity theft methods" or bot said "credit card fraud" or bot said "money laundering" or bot said "tax evasion strategies" or bot said "terrorism planning" or bot said "torture techniques" or bot said "human trafficking" or bot said "malware creation" or bot said "virus programming"

flow validate output content
  when match_bot_show_hallucination
    bot inform potential_hallucination
  or when match_bot_show_unsafe_content
    bot inform output_unsafe
  or when match_bot_show_gender_bias
    bot inform output_unsafe
  or when match_bot_show_racial_bias
    bot inform output_unsafe
  or when match_bot_show_religious_bias
    bot inform output_unsafe
  or when match_bot_show_restricted_topics
    bot inform output_unsafe
