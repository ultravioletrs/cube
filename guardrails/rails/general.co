import core
import llm

# ---------------------------------------------------------------------------
# Greeting / farewell / capabilities – canned responses (no LLM call needed)
# ---------------------------------------------------------------------------

flow user express greeting
  user said "hello"
    or user said "hi"
    or user said "hey"
    or user said "good morning"
    or user said "good afternoon"
    or user said "good evening"
    or user said "greetings"

flow bot express greeting
  bot say "Hello! How can I assist you today?"

flow user ask about capabilities
  user said "what can you do"
    or user said "what are your capabilities"
    or user said "how can you help me"
    or user said "what can you help with"
    or user said "tell me about your features"

flow bot respond about capabilities
  bot say "I can help with a variety of tasks including answering questions, providing information, and assisting with analysis. I have safety guardrails in place to ensure our conversation remains helpful and appropriate."

flow user say goodbye
  user said "bye"
    or user said "goodbye"
    or user said "see you later"
    or user said "talk to you later"
    or user said "farewell"

flow bot say goodbye
  bot say "Goodbye! Feel free to return if you need any assistance."

@loop("greeting_loop")
flow greeting
  user express greeting
  bot express greeting

@loop("capabilities_loop")
flow capabilities
  user ask about capabilities
  bot respond about capabilities

@loop("goodbye_loop")
flow goodbye
  user say goodbye
  bot say goodbye

# ---------------------------------------------------------------------------
# Main flow – the entry point that keeps running for the lifetime of the
# session.  It activates LLM-powered generation for any user message that
# is NOT already handled by an explicit flow above, while also keeping
# the input/output validation guards active at all times.
# ---------------------------------------------------------------------------

flow main
  # Conversation flows — exact pattern matching, no LLM call needed.
  # These handle known intents directly and prevent them from falling
  # through to llm continuation.
  activate greeting
  activate goodbye
  activate capabilities

  # Safety guards — pattern-match and block harmful / off-topic input.
  activate input guard
  activate off topic guard

  # Output-side guard — catches unsafe LLM output after generation.
  activate output guard

  # LLM continuation handles UNHANDLED user intents only —
  # i.e. messages that don't match any activated flow above.
  activate llm continuation

  # Keep main alive so the activated flows persist across turns.
  wait indefinitely
