# GCP Configuration
project_id     = "your-gcp-project-id"
region         = "us-central1"
vm_name        = "cube-cvm-01"
machine_type   = "n2d-standard-2"  # 2 vCPU, 8GB RAM

# Confidential Computing
min_cpu_platform            = "AMD Milan"
confidential_instance_type  = "SEV"  # or "SEV_SNP" for higher security

# Cloud-init configuration
cloud_init_config = "../cloud-init/cube-agent-config.yml"
